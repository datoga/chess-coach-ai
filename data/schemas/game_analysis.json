{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "game_analysis",
  "title": "Game Analysis",
  "type": "object",
  "required": ["game_id", "user_color", "result", "acpl", "dqm", "critical_moments"],
  "properties": {
    "game_id": {
      "type": "string"
    },
    "user_color": {
      "type": "string",
      "enum": ["white", "black"]
    },
    "result": {
      "type": "string",
      "enum": ["1-0", "0-1", "1/2"]
    },
    "acpl": {
      "type": "number"
    },
    "dqm": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "critical_moments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "move_number": { "type": "integer" },
          "user_move": { "type": "string" },
          "best_move": { "type": "string" },
          "maia_prediction": { "type": "string" },
          "maia_level": { "type": "string" },
          "eval_loss_cp": { "type": "number" },
          "classification": {
            "type": "string",
            "enum": ["blunder", "mistake", "inaccuracy", "good", "excellent", "best"]
          },
          "explanation": { "type": "string" },
          "training_theme": { "type": "string" }
        }
      }
    },
    "opening_accuracy": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "middlegame_accuracy": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "endgame_accuracy": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "structure_played": {
      "type": "string"
    },
    "structure_performance_percentile": {
      "type": "number"
    },
    "recommended_study": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
