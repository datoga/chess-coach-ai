{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "training_insights",
  "title": "Training Insights",
  "type": "object",
  "required": ["training_insights"],
  "properties": {
    "training_insights": {
      "type": "object",
      "properties": {
        "game_id": { "type": "string" },
        "date": { "type": "string" },
        "insights": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "theme": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["critical", "important", "minor"]
              },
              "phase": {
                "type": "string",
                "enum": ["openings", "middlegame", "endgame", "tactics"]
              },
              "description": { "type": "string" },
              "position_fen": { "type": "string" },
              "user_move": { "type": "string" },
              "best_move": { "type": "string" },
              "study_recommendation": { "type": "string" },
              "tags": {
                "type": "array",
                "items": { "type": "string" }
              },
              "recurrence": { "type": "integer" }
            }
          }
        },
        "pattern_summary": {
          "type": "object",
          "properties": {
            "strengths_confirmed": {
              "type": "array",
              "items": { "type": "string" }
            },
            "weaknesses_confirmed": {
              "type": "array",
              "items": { "type": "string" }
            },
            "new_weakness_detected": {
              "type": "array",
              "items": { "type": "string" }
            },
            "improvement_since_last": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "roadmap_update": {
          "type": "object",
          "properties": {
            "increase_priority": {
              "type": "array",
              "items": { "type": "string" }
            },
            "decrease_priority": {
              "type": "array",
              "items": { "type": "string" }
            },
            "add_topic": {
              "type": "array",
              "items": { "type": "string" }
            },
            "suggested_block_rebalance": {
              "type": "object",
              "properties": {
                "openings": { "type": "integer" },
                "middlegame": { "type": "integer" },
                "endgame": { "type": "integer" },
                "tactics": { "type": "integer" }
              },
              "additionalProperties": false
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
